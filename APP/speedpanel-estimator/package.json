{
  "name": "speedpanel-estimator",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build",
    "dev": "vite --host 0.0.0.0",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rls": "supabase test db",
    "test:e2e": "playwright test",
    "check:e2e-drift": "node scripts/check-e2e-drift.mjs",
    "depcruise": "depcruise --config .dependency-cruiser.js src",
    "depcruise:graph": "depcruise --config .dependency-cruiser.js --output-type mermaid src > depcruise-graph.mmd"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Tailwind-ready React/Vite Speedpanel estimator",
  "dependencies": {
    "@supabase/supabase-js": "^2.110.1",
    "lucide-react": "^1.23.0",
    "minisearch": "^7.2.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "dependency-cruiser": "^18.1.0",
    "dotenv": "^17.4.2",
    "jsdom": "^29.1.1",
    "pdf-parse": "^2.4.5",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
