# Copy to .env.test (gitignored) and fill in real values before running
# `npm run test:e2e`. See e2e/README.md for the full persona table.
#
# VITE_SUPABASE_URL / VITE_SUPABASE_PUBLISHABLE_KEY only need setting if
# you're pointing the dev server at a DIFFERENT project than the app's
# built-in default (src/lib/supabaseClient.ts) -- omit them to use the
# default project.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# One shared password for every seeded E2E persona (see supabase/seed.sql).
E2E_PASSWORD=

E2E_ADMIN_EMAIL=admin@e2e.test
E2E_PROJECT_MANAGER_EMAIL=project-manager@e2e.test
E2E_BDM_EMAIL=bdm@e2e.test
E2E_INTERNAL_SALES_EMAIL=internal-sales@e2e.test
E2E_DISPATCH_EMAIL=dispatch@e2e.test
E2E_TECHNICAL_EMAIL=technical@e2e.test
E2E_COMPANY_ADMIN_EMAIL=company-admin@e2e.test
E2E_MEMBER_EMAIL=member@e2e.test
E2E_OUTSIDER_EMAIL=outsider@e2e.test
E2E_UNASSIGNED_EMAIL=unassigned@e2e.test

# Override only if the dev server runs somewhere other than
# http://localhost:5183 (playwright.config.ts's webServer starts it there
# by default).
PLAYWRIGHT_TEST_BASE_URL=
